//@version=6
// ─────────────────────────────────────────────────────────────────────
// BTC Flip Bot V1 — MTF Engulfing Signals (BTCUSDT 1H 2×)
//
// Author:  Jagadeesh Manne
// Version: V1
//
// Signal indicator version — shows entry signals, conditions dashboard,
// and alert-ready triggers. No simulated trades.
//
// Backtested in Python on 5yr Binance BTCUSDT data:
// $10K → $241K, +89.1% CAGR, -19.5% DD, PF 5.50, 43 trades
// ─────────────────────────────────────────────────────────────────────
indicator("BTC Flip Bot V6 — MTF Engulfing Signals", overlay=true, max_labels_count=500)

// ─── Inputs ───
grpEntry       = "📊 Entry Filters"
rsiLongMin     = input.int(45,      "RSI long min", minval=10, maxval=70, group=grpEntry)
rsiShortMax    = input.int(55,      "RSI short max", minval=30, maxval=90, group=grpEntry)
engBodyMult    = input.float(1.0,   "Engulf body multiplier", minval=0.5, maxval=3, step=0.1, group=grpEntry)
atrMaLength    = input.int(50,      "ATR MA length", minval=10, maxval=200, group=grpEntry)
volSmaLength   = input.int(20,      "Volume SMA length", minval=5, maxval=100, group=grpEntry)
volSpikeRatio  = input.float(1.5,   "Volume spike ratio", minval=1.0, maxval=5, step=0.1, group=grpEntry)

grpSL          = "🛑 Stop Loss"
slMaxPct       = input.float(2.5,   "SL max (%)", minval=0.5, maxval=10, step=0.1, group=grpSL) / 100
slBufPct       = input.float(0.1,   "SL buffer (%)", minval=0.0, maxval=1, step=0.05, group=grpSL) / 100

grpCD          = "⏸️ Cooldowns"
sameDirCdHours = input.int(24,      "Same-dir SL cooldown (hours)", minval=0, maxval=168, group=grpCD)
genCdHours     = input.int(2,       "Generic exit cooldown (hours)", minval=0, maxval=24, group=grpCD)

grpAlerts      = "🔔 Alerts"
showAlerts     = input.bool(true,   "Enable alert conditions", group=grpAlerts)

// ─── Higher TF data (causal) ───
dailyClose = request.security(syminfo.tickerid, "1D", close[1], lookahead=barmerge.lookahead_off)
dailyEma50 = request.security(syminfo.tickerid, "1D", ta.ema(close, 50)[1], lookahead=barmerge.lookahead_off)
rsi4h      = request.security(syminfo.tickerid, "240", ta.rsi(close, 14)[1], lookahead=barmerge.lookahead_off)

dailyBull  = dailyClose > dailyEma50
dailyBear  = dailyClose < dailyEma50
h4ConfBull = rsi4h > 50
h4ConfBear = rsi4h < 50

// ─── 1H indicators ───
rsi1h = ta.rsi(close, 14)
[macdLine, macdSignal, macdHist] = ta.macd(close, 12, 26, 9)
atr14  = ta.atr(14)
atrMa  = ta.sma(atr14, atrMaLength)
highVol = atr14 > atrMa
volSma = ta.sma(volume, volSmaLength)
volOk  = volume > volSpikeRatio * volSma

// ─── Engulfing patterns ───
bodySize = math.abs(close - open)
prevBody = bodySize[1]
bullEngulfing = close[1] < open[1] and close > open and close >= open[1] and open <= close[1] and bodySize > prevBody * engBodyMult
bearEngulfing = close[1] > open[1] and close < open and open >= close[1] and close <= open[1] and bodySize > prevBody * engBodyMult

// ─── Entry stack ───
longStack  = rsi1h > rsiLongMin and macdLine > macdSignal and bullEngulfing and highVol and volOk
shortStack = rsi1h < rsiShortMax and macdLine < macdSignal and bearEngulfing and highVol and volOk
longSignal  = longStack and dailyBull and h4ConfBull
shortSignal = shortStack and dailyBear and h4ConfBear

// ─── Pattern-based SL levels (for display) ───
patternLowLong  = math.min(low, low[1]) * (1 - slBufPct)
cappedLowLong   = close * (1 - slMaxPct)
stopLong        = math.max(patternLowLong, cappedLowLong)

patternHighShort = math.max(high, high[1]) * (1 + slBufPct)
cappedHighShort  = close * (1 + slMaxPct)
stopShort        = math.min(patternHighShort, cappedHighShort)

// ─── Cooldown tracking (simplified — tracks signals, not actual trades) ───
var int lastLongSlBar  = na
var int lastShortSlBar = na
var int lastSignalBar  = na

// Track when signals fire for cooldown display
if longSignal
    lastSignalBar := bar_index
if shortSignal
    lastSignalBar := bar_index

longCdBlocked  = not na(lastLongSlBar) and (bar_index - lastLongSlBar) < sameDirCdHours
shortCdBlocked = not na(lastShortSlBar) and (bar_index - lastShortSlBar) < sameDirCdHours
exitCdBlocked  = not na(lastSignalBar) and (bar_index - lastSignalBar) < genCdHours and not longSignal and not shortSignal

canGoLong  = longSignal and not longCdBlocked
canGoShort = shortSignal and not shortCdBlocked

// ─── Count conditions met ───
longCount = (dailyBull ? 1 : 0) + (h4ConfBull ? 1 : 0) + (rsi1h > rsiLongMin ? 1 : 0) + (macdLine > macdSignal ? 1 : 0) + (bullEngulfing ? 1 : 0) + (highVol ? 1 : 0) + (volOk ? 1 : 0)
shortCount = (dailyBear ? 1 : 0) + (h4ConfBear ? 1 : 0) + (rsi1h < rsiShortMax ? 1 : 0) + (macdLine < macdSignal ? 1 : 0) + (bearEngulfing ? 1 : 0) + (highVol ? 1 : 0) + (volOk ? 1 : 0)

// ─── Signal labels on chart ───
if canGoLong
    slPct = (close - stopLong) / close * 100
    label.new(bar_index, low, "LONG\nSL: $" + str.tostring(stopLong, "#") + " (" + str.tostring(slPct, "#.#") + "%)",
         style=label.style_label_up, color=color.green, textcolor=color.white, size=size.normal)

if canGoShort
    slPct = (stopShort - close) / close * 100
    label.new(bar_index, high, "SHORT\nSL: $" + str.tostring(stopShort, "#") + " (" + str.tostring(slPct, "#.#") + "%)",
         style=label.style_label_down, color=color.red, textcolor=color.white, size=size.normal)

// ─── Visuals ───
plot(dailyEma50, "Daily EMA50", color=color.new(color.yellow, 40), linewidth=2)
plotshape(canGoLong, title="Long Signal", style=shape.triangleup, location=location.belowbar, color=color.green, size=size.small)
plotshape(canGoShort, title="Short Signal", style=shape.triangledown, location=location.abovebar, color=color.red, size=size.small)

// Plot SL level when signal fires
plot(canGoLong ? stopLong : na, "Long SL", color=color.new(color.red, 0), style=plot.style_cross, linewidth=2)
plot(canGoShort ? stopShort : na, "Short SL", color=color.new(color.red, 0), style=plot.style_cross, linewidth=2)

// ─── Alerts ───
alertcondition(canGoLong, title="LONG Signal", message="BTC Flip Bot: LONG signal fired. All 7 conditions met. Check chart for SL level.")
alertcondition(canGoShort, title="SHORT Signal", message="BTC Flip Bot: SHORT signal fired. All 7 conditions met. Check chart for SL level.")
alertcondition(longCount >= 5, title="LONG 5/7+ conditions", message="BTC Flip Bot: 5+ of 7 LONG conditions met. Signal approaching.")
alertcondition(shortCount >= 5, title="SHORT 5/7+ conditions", message="BTC Flip Bot: 5+ of 7 SHORT conditions met. Signal approaching.")

// ─── Dashboard ───
if barstate.islast
    var table dash = table.new(position.top_right, 3, 11, border_width=1)

    // Header
    table.cell(dash, 0, 0, "BTC Flip Bot", bgcolor=color.gray, text_color=color.white)
    table.cell(dash, 1, 0, "LONG", bgcolor=color.gray, text_color=color.white)
    table.cell(dash, 2, 0, "SHORT", bgcolor=color.gray, text_color=color.white)

    // Condition count
    lClr = longCount >= 7 ? color.green : longCount >= 5 ? color.orange : color.gray
    sClr = shortCount >= 7 ? color.red : shortCount >= 5 ? color.orange : color.gray
    table.cell(dash, 1, 1, str.tostring(longCount) + "/7", bgcolor=lClr, text_color=color.white)
    table.cell(dash, 2, 1, str.tostring(shortCount) + "/7", bgcolor=sClr, text_color=color.white)
    table.cell(dash, 0, 1, "Score")

    // Individual conditions
    table.cell(dash, 0, 2, "Daily EMA50")
    table.cell(dash, 1, 2, dailyBull ? "BULL ✓" : "✗", text_color=dailyBull ? color.green : color.gray)
    table.cell(dash, 2, 2, dailyBear ? "BEAR ✓" : "✗", text_color=dailyBear ? color.red : color.gray)

    table.cell(dash, 0, 3, "4H RSI")
    table.cell(dash, 1, 3, h4ConfBull ? str.tostring(rsi4h, "#.#") + " ✓" : str.tostring(rsi4h, "#.#"), text_color=h4ConfBull ? color.green : color.gray)
    table.cell(dash, 2, 3, h4ConfBear ? str.tostring(rsi4h, "#.#") + " ✓" : str.tostring(rsi4h, "#.#"), text_color=h4ConfBear ? color.red : color.gray)

    table.cell(dash, 0, 4, "1H RSI")
    rsiOkL = rsi1h > rsiLongMin
    rsiOkS = rsi1h < rsiShortMax
    table.cell(dash, 1, 4, str.tostring(rsi1h, "#.#") + (rsiOkL ? " ✓" : ""), text_color=rsiOkL ? color.green : color.gray)
    table.cell(dash, 2, 4, str.tostring(rsi1h, "#.#") + (rsiOkS ? " ✓" : ""), text_color=rsiOkS ? color.red : color.gray)

    table.cell(dash, 0, 5, "MACD")
    macdBull = macdLine > macdSignal
    table.cell(dash, 1, 5, macdBull ? "▲ bull ✓" : "▼ bear", text_color=macdBull ? color.green : color.gray)
    table.cell(dash, 2, 5, macdBull ? "▲ bull" : "▼ bear ✓", text_color=macdBull ? color.gray : color.red)

    table.cell(dash, 0, 6, "Engulfing")
    table.cell(dash, 1, 6, bullEngulfing ? "✓" : "—", text_color=bullEngulfing ? color.green : color.gray)
    table.cell(dash, 2, 6, bearEngulfing ? "✓" : "—", text_color=bearEngulfing ? color.red : color.gray)

    table.cell(dash, 0, 7, "ATR > MA")
    atrTxt = str.tostring(atr14, "#") + " / " + str.tostring(atrMa, "#")
    table.cell(dash, 1, 7, highVol ? atrTxt + " ✓" : atrTxt, text_color=highVol ? color.green : color.gray)
    table.cell(dash, 2, 7, highVol ? atrTxt + " ✓" : atrTxt, text_color=highVol ? color.red : color.gray)

    table.cell(dash, 0, 8, "Vol spike")
    volRatio = volSma > 0 ? volume / volSma : 0.0
    volTxt = str.tostring(volRatio, "#.##") + "x"
    table.cell(dash, 1, 8, volOk ? volTxt + " ✓" : volTxt, text_color=volOk ? color.green : color.gray)
    table.cell(dash, 2, 8, volOk ? volTxt + " ✓" : volTxt, text_color=volOk ? color.red : color.gray)

    // SL levels
    table.cell(dash, 0, 9, "SL level")
    table.cell(dash, 1, 9, "$" + str.tostring(stopLong, "#,###"))
    table.cell(dash, 2, 9, "$" + str.tostring(stopShort, "#,###"))

    // Price
    table.cell(dash, 0, 10, "Price")
    table.cell(dash, 1, 10, "$" + str.tostring(close, "#,###"), text_color=color.white)
    table.cell(dash, 2, 10, "$" + str.tostring(close, "#,###"), text_color=color.white)

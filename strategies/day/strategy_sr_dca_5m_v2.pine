//@version=6
// ─────────────────────────────────────────────────────────────────────
// S/R DCA Day Trader (5m) V2 — 1h S/R Levels
//
// Experimental: use the LAST CLOSED 1h bar's high/low/mid as S/R levels
// instead of the prior DAY's H/L/mid.
//
// Key consequence: ranges are ~10× smaller.
//   - Typical BTC 1d range: 2-4%    → TP distance 1-2% (plenty of room)
//   - Typical BTC 1h range: 0.2-0.8% → TP distance 0.1-0.4% (tight)
//
// Params retuned to match the smaller range:
//   - DCA spacing: 1% → 0.3%       (1% would rarely trigger at 1h scale)
//   - SL below worst: 2% → 0.5%    (2% would be 5× the typical 1h range)
//   - Support zone: 0.2% → 0.1%    (proportionally tighter)
//
// Everything else identical to V1:
//   - 1h EMA20 bias (unchanged)
//   - Volume + RSI filters (unchanged)
//   - EOD flatten at UTC 23:00
//   - Max 1 cycle per UTC day (may be too restrictive — might want per hour)
//
// ⚠ WARNING:
//   This is a totally different strategy character. Commissions (0.08%
//   round-trip) eat a much larger fraction of profit at 1h scale.
//   Expect much lower PF, possibly net-negative after fees.
//   Test first; don't deploy without seeing favorable TV numbers.
// ─────────────────────────────────────────────────────────────────────

leverageInput = input.float(2.0, "Leverage cap", minval=1, maxval=10, step=0.5)

strategy("S/R DCA Day Trader (5m) V2 — 1h S/R", overlay=true, initial_capital=5000,
     default_qty_type=strategy.percent_of_equity, default_qty_value=95,
     pyramiding=3, calc_on_order_fills=false, calc_on_every_tick=false,
     process_orders_on_close=true, commission_type=strategy.commission.percent,
     commission_value=0.04, slippage=3,
     margin_long=0, margin_short=0)

// ─── Risk ───
grpRisk = "⚙️ Risk"
riskPct = input.float(6.0, "Total risk per cycle (%)", minval=0.1, maxval=15, step=0.5, group=grpRisk) / 100

// ─── S/R source (V2 core change) ───
grpSR = "📍 S/R Timeframe (V2)"
srTf = input.timeframe("60", "S/R reference timeframe", options=["60", "120", "240", "360", "720", "D"], group=grpSR,
     tooltip="Which timeframe's prior bar defines support/resistance. V2 default 60 (1h). V1 used D (daily). Try 240 (4h) as a middle ground.")

// ─── DCA ───
grpDCA = "📊 S/R DCA"
dcaLevels    = input.int(2, "DCA levels", minval=1, maxval=5, group=grpDCA)
dcaSpacing   = input.float(0.3, "DCA spacing (%)", minval=0.05, maxval=3, step=0.05, group=grpDCA,
     tooltip="V2 default 0.3% (vs V1's 1%). 1h ranges are ~10× smaller; 1% would rarely trigger.") / 100
slBelowWorst = input.float(0.5, "SL below worst entry (%)", minval=0.1, maxval=5, step=0.1, group=grpDCA,
     tooltip="V2 default 0.5% (vs V1's 2%). 2% is ~5× a typical 1h range — SL would almost never trigger.") / 100
supportZone  = input.float(0.1, "S/R entry zone (%)", minval=0.02, maxval=1, step=0.02, group=grpDCA,
     tooltip="V2 default 0.1% (vs V1's 0.2%). Tighter zone for tighter 1h range.") / 100
closeHour    = input.int(20, "Force flatten at UTC hour", minval=12, maxval=23, group=grpDCA,
     tooltip="Matches main pine default. Validated at 20 (vs 23): +2.15% P&L, +9.5pp WR.")

// ─── Quality filters ───
grpFilter = "🎯 Entry Quality Filters"
useVolumeFilter  = input.bool(true, "Require volume confirmation at entry", group=grpFilter)
volMult          = input.float(1.2, "Volume × 20-bar avg", minval=0.5, maxval=3.0, step=0.1, group=grpFilter)

useRsiFilter     = input.bool(true, "Skip extreme RSI (falling/flying knives)", group=grpFilter)
rsiPeriod        = input.int(14, "RSI period", minval=5, maxval=30, step=1, group=grpFilter)
rsiLow           = input.float(25.0, "Skip long if RSI <", minval=10, maxval=40, step=1, group=grpFilter)
rsiHigh          = input.float(75.0, "Skip short if RSI >", minval=60, maxval=90, step=1, group=grpFilter)

// ─── S/R levels from configured TF (V2: default 60 = 1h prior bar) ───
prevH = request.security(syminfo.tickerid, srTf, high[1],  lookahead=barmerge.lookahead_off)
prevL = request.security(syminfo.tickerid, srTf, low[1],   lookahead=barmerge.lookahead_off)
prevMid = (prevH + prevL) / 2.0

// ─── 1h EMA bias (unchanged from V1) ───
grpBias = "🎯 1h Bias"
hourEmaLen = input.int(20, "1h EMA period", minval=5, maxval=100, step=1, group=grpBias)
hourClose  = request.security(syminfo.tickerid, "60", close[1],                     lookahead=barmerge.lookahead_off)
hourEma    = request.security(syminfo.tickerid, "60", ta.ema(close, hourEmaLen)[1], lookahead=barmerge.lookahead_off)
hourBull   = hourClose > hourEma
hourBear   = hourClose < hourEma

// ─── Time ───
utcH = hour(time, "UTC")
newDay = ta.change(dayofmonth) != 0

// ─── Filter computations ───
volAvg = ta.sma(volume, 20)
volOk = not useVolumeFilter or volume >= volMult * volAvg

rsiVal = ta.rsi(close, rsiPeriod)
rsiOkLong  = not useRsiFilter or rsiVal >= rsiLow
rsiOkShort = not useRsiFilter or rsiVal <= rsiHigh

// ─── State ───
var int   filledCount = 0
var float firstEntryPx = na
var float worstEntryPx = na
var int   cycleClosedOnDay = -1

if newDay
    cycleClosedOnDay := -1

cycleDone = cycleClosedOnDay == dayofmonth

// ─── Per-level sizing ───
worstSlDistPct = (dcaLevels - 1) * dcaSpacing + slBelowWorst
totalNotional = strategy.equity * 0.95 * riskPct / worstSlDistPct
perLevelQty = totalNotional / close / dcaLevels
qtyCap = (strategy.equity * 0.95 * leverageInput) / close / dcaLevels
perLevelQty := math.min(perLevelQty, qtyCap)

// ─── L1 entry: touch prev_L (for longs) or prev_H (for shorts) ───
l1LongOk = hourBull and not cycleDone and strategy.position_size == 0 and utcH < closeHour
     and low <= prevL * (1 + supportZone) and low > prevL * (1 - 0.01)
     and volOk and rsiOkLong

l1ShortOk = hourBear and not cycleDone and strategy.position_size == 0 and utcH < closeHour
     and high >= prevH * (1 - supportZone) and high < prevH * (1 + 0.01)
     and volOk and rsiOkShort

if l1LongOk and perLevelQty > 0
    entryPx = prevL * (1 + supportZone / 2)
    strategy.entry("L1", strategy.long, qty=perLevelQty, limit=entryPx)
    firstEntryPx := entryPx
    worstEntryPx := entryPx
    filledCount := 1

if l1ShortOk and perLevelQty > 0
    entryPx = prevH * (1 - supportZone / 2)
    strategy.entry("S1", strategy.short, qty=perLevelQty, limit=entryPx)
    firstEntryPx := entryPx
    worstEntryPx := entryPx
    filledCount := 1

// ─── DCA ───
if strategy.position_size > 0 and filledCount >= 1 and filledCount < dcaLevels
    nextDcaPx = worstEntryPx * (1 - dcaSpacing)
    if low <= nextDcaPx
        idStr = "L" + str.tostring(filledCount + 1)
        strategy.entry(idStr, strategy.long, qty=perLevelQty, limit=nextDcaPx)
        worstEntryPx := nextDcaPx
        filledCount := filledCount + 1

if strategy.position_size < 0 and filledCount >= 1 and filledCount < dcaLevels
    nextDcaPx = worstEntryPx * (1 + dcaSpacing)
    if high >= nextDcaPx
        idStr = "S" + str.tostring(filledCount + 1)
        strategy.entry(idStr, strategy.short, qty=perLevelQty, limit=nextDcaPx)
        worstEntryPx := nextDcaPx
        filledCount := filledCount + 1

// ─── TP + SL ───
tpLongPx  = prevMid
tpShortPx = prevMid
slLongPx  = worstEntryPx * (1 - slBelowWorst)
slShortPx = worstEntryPx * (1 + slBelowWorst)

if strategy.position_size > 0 and not na(worstEntryPx)
    strategy.exit("xL1", from_entry="L1", limit=tpLongPx, stop=slLongPx)
    if filledCount >= 2
        strategy.exit("xL2", from_entry="L2", limit=tpLongPx, stop=slLongPx)
    if filledCount >= 3
        strategy.exit("xL3", from_entry="L3", limit=tpLongPx, stop=slLongPx)

if strategy.position_size < 0 and not na(worstEntryPx)
    strategy.exit("xS1", from_entry="S1", limit=tpShortPx, stop=slShortPx)
    if filledCount >= 2
        strategy.exit("xS2", from_entry="S2", limit=tpShortPx, stop=slShortPx)
    if filledCount >= 3
        strategy.exit("xS3", from_entry="S3", limit=tpShortPx, stop=slShortPx)

// ─── EOD flatten ───
if utcH >= closeHour and strategy.position_size != 0
    strategy.close_all(comment="EOD flatten")

// ─── Cycle reset ───
if strategy.position_size == 0 and strategy.position_size[1] != 0
    cycleClosedOnDay := dayofmonth
    filledCount := 0
    firstEntryPx := na
    worstEntryPx := na

// ─── Visuals ───
plot(prevH, "Prev H (1h)",   color=color.new(color.red,   50), style=plot.style_linebr)
plot(prevL, "Prev L (1h)",   color=color.new(color.green, 50), style=plot.style_linebr)
plot(prevMid, "Prev Mid (TP)", color=color.new(color.aqua, 30), style=plot.style_linebr)
plot(strategy.position_size != 0 and not na(worstEntryPx)
     ? (strategy.position_size > 0 ? slLongPx : slShortPx) : na,
     "Active SL", color=color.new(color.red, 20), style=plot.style_linebr, linewidth=2)
plot(hourEma, "1h EMA", color=color.new(color.purple, 20), linewidth=2)

plotshape(l1LongOk,  "L1",  shape.triangleup,   location.belowbar, color.green, size=size.small)
plotshape(l1ShortOk, "S1",  shape.triangledown, location.abovebar, color.red,   size=size.small)

wrongTf = timeframe.period != "5"
if barstate.islast and wrongTf
    var table tfWarn = table.new(position.bottom_center, 1, 1, border_width=2, border_color=color.red)
    table.cell(tfWarn, 0, 0,
         "⚠ Chart TF is " + timeframe.period + " — designed for 5m",
         bgcolor=color.new(color.red, 15), text_color=color.white, text_size=size.normal)

// Dashboard
if barstate.islast
    var table dash = table.new(position.top_right, 2, 10, border_width=1)
    table.cell(dash, 0, 0, "S/R DCA V2", bgcolor=color.gray, text_color=color.white)
    table.cell(dash, 1, 0, str.tostring(leverageInput, "#.#") + "× LEV", bgcolor=color.teal, text_color=color.white)
    table.cell(dash, 0, 1, "S/R timeframe")
    table.cell(dash, 1, 1, srTf + (srTf == "60" ? " (1h)" : srTf == "240" ? " (4h)" : srTf == "D" ? " (1d)" : ""))
    table.cell(dash, 0, 2, "1h bias")
    table.cell(dash, 1, 2, hourBull ? "BULL ✓" : "BEAR", text_color=hourBull ? color.green : color.red)
    table.cell(dash, 0, 3, "Prev H / L / Mid")
    table.cell(dash, 1, 3, str.tostring(prevL, "#.##") + " / " + str.tostring(prevMid, "#.##") + " / " + str.tostring(prevH, "#.##"))
    table.cell(dash, 0, 4, "Range %")
    table.cell(dash, 1, 4, str.tostring((prevH - prevL) / prevL * 100, "#.###") + "%")
    table.cell(dash, 0, 5, "DCA spacing / SL")
    table.cell(dash, 1, 5, str.tostring(dcaSpacing * 100, "#.##") + "% / " + str.tostring(slBelowWorst * 100, "#.##") + "%")
    table.cell(dash, 0, 6, "Filled")
    table.cell(dash, 1, 6, str.tostring(filledCount) + "/" + str.tostring(dcaLevels))
    table.cell(dash, 0, 7, "Position")
    table.cell(dash, 1, 7, strategy.position_size > 0 ? "LONG" : strategy.position_size < 0 ? "SHORT" : "FLAT",
         text_color=strategy.position_size > 0 ? color.green : strategy.position_size < 0 ? color.red : color.gray)
    table.cell(dash, 0, 8, "Cycle done today")
    table.cell(dash, 1, 8, cycleDone ? "YES" : "no")
    table.cell(dash, 0, 9, "Equity")
    table.cell(dash, 1, 9, "$" + str.tostring(strategy.equity, "#,###"))

//@version=6
// ─────────────────────────────────────────────────────────────────────
// S/R DCA Day Trader (5m)
//
// ⚠ DESIGNED FOR: BTCUSDT · 5-minute timeframe · ONLY.
//   Tuned to BTC's daily range, RSI behavior, and S/R touch frequency.
//   Other symbols and timeframes have NOT been validated.
//   The strategy shows a wrong-TF warning on anything other than 5m.
//
// 5m support/resistance DCA day trader. Buys at prev_day low, shorts at
// prev_day high, averages down once if price moves further against, exits
// at prev_day midpoint. Force-flattens at 20:00 UTC, never holds overnight.
// 1 cycle per UTC day max.
//
// Logic:
//   - Entry: 5m low touches prev_L (LONG) or 5m high touches prev_H (SHORT),
//     within a 0.05% zone
//   - Filters: RSI anti-extreme (skip LONG <25 / SHORT >75) + volume ≥ 1.2× SMA
//   - DCA: 1 add at worst_entry × (1 ∓ 0.8%)
//   - TP: prev_day midpoint (DEFAULT). Optional "smart" mode adapts to
//     avg entry after DCA but tested worse on the 5w window (+20% vs +32%).
//   - SL: worst_entry × (1 ∓ 2%) — moves with each DCA leg
//   - EOD: force flatten at configurable UTC hour (default 20:00)
//
// Tested on BTCUSDT 5m. Recent 5w: +32.35% / PF 3.65 / 43 trades (default
// settings); +35.20% with fixed-4% TP variant.
//
// ⚠ Regime warning: a 2.3-year python backtest returned -72.78% / DD 82%.
// The strategy is regime-favorable (works in mean-reverting markets) but
// breaks down in strong trends. Paper-trade or testnet first.
//
// Live testnet deployment: http://34.14.124.215:8888/dashboard.html?env=testnet
// ─────────────────────────────────────────────────────────────────────

leverageInput = input.float(2.0, "Leverage cap", minval=1, maxval=10, step=0.5)

strategy("S/R DCA Day Trader (5m)", overlay=true, initial_capital=5000,
     default_qty_type=strategy.percent_of_equity, default_qty_value=95,
     pyramiding=3, calc_on_order_fills=false, calc_on_every_tick=false,
     process_orders_on_close=true, commission_type=strategy.commission.percent,
     commission_value=0.04, slippage=3,
     margin_long=0, margin_short=0)

// ─── Risk ───
grpRisk = "⚙️ Risk"
riskPct = input.float(6.0, "Total risk per cycle (%)", minval=0.1, maxval=15, step=0.5, group=grpRisk,
     tooltip="At 6% the TV 5-week test gave +14.07% / 9.75% DD. Drop to 5% for safer, raise to 8% for aggressive.") / 100

// ─── DCA ───
grpDCA = "📊 S/R DCA"
dcaLevels    = input.int(2, "DCA levels", minval=1, maxval=5, group=grpDCA,
     tooltip="5m uses 2 levels. Each DCA adds 1 leg at worst_entry × (1 ± dcaSpacing).")
dcaSpacing   = input.float(0.8, "DCA spacing (%)", minval=0.3, maxval=3, step=0.1, group=grpDCA,
     tooltip="Distance between DCA legs. Tighter spacing fills DCA more often with a tighter avg entry.") / 100
slBelowWorst = input.float(2.0, "SL below worst entry (%)", minval=0.5, maxval=5, step=0.1, group=grpDCA)/100
supportZone  = input.float(0.05, "S/R entry zone (%)", minval=0.05, maxval=1, step=0.05, group=grpDCA,
     tooltip="How close to prev_H/prev_L the bar high/low must be to count as a touch. 0.05% = direct touch only, very selective. Wider zones fire on near-misses but hurt win rate.") / 100
useEodFlatten = input.bool(true, "Force flatten at EOD UTC hour", group=grpDCA,
     tooltip="When ON: position closes at closeHour UTC and entries are blocked past that hour. When OFF: position rides until TP or SL hits, no time limit. Backtest history says EOD-on is safer; OFF lets winners run but exposes to overnight regime shifts.")
closeHour    = input.int(20, "Force flatten at UTC hour", minval=12, maxval=23, group=grpDCA,
     tooltip="Only used when EOD flatten is ON. Backtest: 20 is conservative, 23 lets trades work longer.")

// ─── Quality filters ───
grpFilter = "🎯 Entry Quality Filters"
useVolumeFilter  = input.bool(true, "Require volume confirmation at entry", group=grpFilter)
volMult          = input.float(1.2, "Volume × 20-bar avg", minval=0.5, maxval=3.0, step=0.1, group=grpFilter,
     tooltip="Entry bar volume must exceed this × 20-bar SMA volume.")

// RSI filter — anti-extreme protection:
//   Skip LONG if RSI < 25 (don't catch falling knives)
//   Skip SHORT if RSI > 75 (don't catch flying knives)
// Inverted logic (require extremes) was tested and rejected — backtest worse.
useRsiFilter     = input.bool(true, "Skip extreme RSI (falling/flying knives)", group=grpFilter)
rsiPeriod        = input.int(14, "RSI period", minval=5, maxval=30, step=1, group=grpFilter,
     tooltip="14 = 70-min lookback on 5m. Standard.")
rsiLow           = input.float(25.0, "Skip long if RSI <", minval=10, maxval=40, step=1, group=grpFilter)
rsiHigh          = input.float(75.0, "Skip short if RSI >", minval=60, maxval=90, step=1, group=grpFilter)

// (Range gate and close confirm removed — kept off in user's tested config)
useRangeGate    = false  // disabled
minPrevRange    = 0.0
useCloseConfirm = false  // disabled

// ─── Take Profit ───
grpTP = "🎯 Take Profit"
tpMode = input.string("prev_mid", "TP target", options=["prev_mid", "hybrid", "smart", "prev_extreme", "fixed_pct"], group=grpTP,
     tooltip="prev_mid (DEFAULT, +32.07% / PF 3.32 / DD 4.80% on Mar 23–May 1) = yesterday's midpoint, fixed S/R anchor. hybrid = prev_mid pre-DCA, then switches to FIRST entry × (1 ∓ tpFixedPct) once DCA fires (gives position more room after averaging worse). smart = whichever of {prev_mid, avg × (1 ∓ smartPct)} is CLOSER to mark — adapts to slippage but takes profit earlier. prev_extreme = full prev_day range (riskier). fixed_pct = N% from FIRST entry, no prev_mid blend.")
smartTpPct = input.float(0.5, "Smart TP: % from avg entry", minval=0.1, maxval=3.0, step=0.1, group=grpTP,
     tooltip="Used in smart mode only. After each DCA leg fills, TP recomputes to avg_entry × (1 ∓ this%). Smaller % = earlier TP, smaller wins. 0.5% scalp tested at +20% / 5w — worse than prev_mid. Try 1.0–1.5% if you want a middle ground.") / 100
tpFixedPct = input.float(4.0, "Fixed TP distance from entry (%)", minval=0.1, maxval=10, step=0.1, group=grpTP,
     tooltip="Used when TP mode = fixed_pct. 4% works on recent 5w TV. ⚠ 2.3y backtest of fixed TP all variants = -71% to -79% — regime-favorable only.") / 100
prevMidOffsetPct = input.float(0.1, "Prev_mid TP offset (%)", minval=-1.0, maxval=1.0, step=0.05, group=grpTP,
     tooltip="Shift the prev_mid TP slightly toward current price for more reliable fills (prev_mid often sits at a thin-liquidity zone where exact-fill is unreliable). 0.1% = TP fires 0.1% before exact mid → smaller wins but higher hit rate. Negative offset = wait past mid for bigger wins (riskier — may miss fill entirely). Set to 0 for exact prev_mid behavior.") / 100

// (Trailing stop tested and removed — too many false trail-outs near peaks.)

// ─── Prior day levels (via security) ───
prevH = request.security(syminfo.tickerid, "1D", high[1],  lookahead=barmerge.lookahead_off)
prevL = request.security(syminfo.tickerid, "1D", low[1],   lookahead=barmerge.lookahead_off)
prevMid = (prevH + prevL) / 2.0

// 1h EMA — chart display only. The strategy doesn't gate entries on bias;
// shown for visual context (bias filter was tested and removed — it blocked
// 60%+ of valid entries because bias flips bear right when price reaches prev_L).
hourEmaLen = 20
hourEma    = request.security(syminfo.tickerid, "60", ta.ema(close, hourEmaLen)[1], lookahead=barmerge.lookahead_off)

// ─── Time ───
utcH = hour(time, "UTC")
newDay = ta.change(dayofmonth) != 0

// ─── Filter computations ───
volAvg = ta.sma(volume, 20)
volOk = not useVolumeFilter or volume >= volMult * volAvg

rsiVal = ta.rsi(close, rsiPeriod)
// Anti-extreme: skip LONG when oversold, skip SHORT when overbought
rsiOkLong  = not useRsiFilter or rsiVal >= rsiLow
rsiOkShort = not useRsiFilter or rsiVal <= rsiHigh

// Range gate — replaces the bias filter as the protective mechanism
prevRangePct = (prevH - prevL) / prevL
rangeOk = not useRangeGate or prevRangePct >= minPrevRange

// Optional close confirmation
closeOkLong  = not useCloseConfirm or close > open
closeOkShort = not useCloseConfirm or close < open

// ─── State ───
var int   filledCount = 0
var float firstEntryPx = na
var float worstEntryPx = na
// Weighted avg entry tracking — needed for "smart" TP mode that recomputes
// the target after each DCA fill. cumNotional / cumQty = avgEntryPx.
var float cumNotional = na
var float cumQty      = na
avgEntryPx = na(cumQty) or cumQty == 0 ? na : cumNotional / cumQty
var int   cycleClosedOnDay = -1

if newDay
    cycleClosedOnDay := -1

cycleDone = cycleClosedOnDay == dayofmonth

// ─── Per-level sizing ───
// Total risk = riskPct of equity; worst-case SL distance from L1 = (N-1)*spacing + slBelow
worstSlDistPct = (dcaLevels - 1) * dcaSpacing + slBelowWorst
totalNotional = strategy.equity * 0.95 * riskPct / worstSlDistPct
perLevelQty = totalNotional / close / dcaLevels
qtyCap = (strategy.equity * 0.95 * leverageInput) / close / dcaLevels
perLevelQty := math.min(perLevelQty, qtyCap)

// ─── L1 entry: touch prev_L (for longs) or prev_H (for shorts) ───
// NO BIAS CHECK. LONG and SHORT both allowed regardless of trend.
inEntryWindow = not useEodFlatten or utcH < closeHour
l1LongOk = not cycleDone and strategy.position_size == 0 and inEntryWindow
     and low <= prevL * (1 + supportZone) and low > prevL * (1 - 0.01)
     and volOk and rsiOkLong
     and rangeOk and closeOkLong

l1ShortOk = not cycleDone and strategy.position_size == 0 and inEntryWindow
     and high >= prevH * (1 - supportZone) and high < prevH * (1 + 0.01)
     and volOk and rsiOkShort
     and rangeOk and closeOkShort

if l1LongOk and perLevelQty > 0
    entryPx = prevL * (1 + supportZone / 2)
    strategy.entry("L1", strategy.long, qty=perLevelQty, limit=entryPx)
    firstEntryPx := entryPx
    worstEntryPx := entryPx
    cumNotional  := entryPx * perLevelQty
    cumQty       := perLevelQty
    filledCount  := 1

if l1ShortOk and perLevelQty > 0
    entryPx = prevH * (1 - supportZone / 2)
    strategy.entry("S1", strategy.short, qty=perLevelQty, limit=entryPx)
    firstEntryPx := entryPx
    worstEntryPx := entryPx
    cumNotional  := entryPx * perLevelQty
    cumQty       := perLevelQty
    filledCount  := 1

// ─── DCA: add next level when price moves spacing% against us ───
if strategy.position_size > 0 and filledCount >= 1 and filledCount < dcaLevels
    nextDcaPx = worstEntryPx * (1 - dcaSpacing)
    if low <= nextDcaPx
        idStr = "L" + str.tostring(filledCount + 1)
        strategy.entry(idStr, strategy.long, qty=perLevelQty, limit=nextDcaPx)
        worstEntryPx := nextDcaPx
        cumNotional  := cumNotional + nextDcaPx * perLevelQty
        cumQty       := cumQty + perLevelQty
        filledCount  := filledCount + 1

if strategy.position_size < 0 and filledCount >= 1 and filledCount < dcaLevels
    nextDcaPx = worstEntryPx * (1 + dcaSpacing)
    if high >= nextDcaPx
        idStr = "S" + str.tostring(filledCount + 1)
        strategy.entry(idStr, strategy.short, qty=perLevelQty, limit=nextDcaPx)
        worstEntryPx := nextDcaPx
        cumNotional  := cumNotional + nextDcaPx * perLevelQty
        cumQty       := cumQty + perLevelQty
        filledCount  := filledCount + 1

// ─── TP + SL (static SL, configurable TP) ───
// prev_mid offsets: shift target slightly toward current price for fill reliability.
// LONG TP is above current → lower it slightly; SHORT TP is below current → raise it.
prevMidLong  = prevMid * (1 - prevMidOffsetPct)
prevMidShort = prevMid * (1 + prevMidOffsetPct)
tpLongFixed  = na(firstEntryPx) ? na : firstEntryPx * (1 + tpFixedPct)
tpShortFixed = na(firstEntryPx) ? na : firstEntryPx * (1 - tpFixedPct)

// Smart TP: only adapts AFTER a DCA leg fills (filledCount > 1). Before
// DCA, the trade rides to prev_mid (the structural mean-reversion target —
// the whole point of the strategy). Once DCA fires (price moved against
// us), avg entry shifts to a worse level, so we add a "% from avg entry"
// target and pick whichever of {prev_mid, avg × (1 ∓ smartTpPct)} is
// CLOSER to current price (easier to hit).
//   For LONG: TP must be ABOVE mark, so easier = LOWER value → math.min
//   For SHORT: TP must be BELOW mark, so easier = HIGHER value → math.max
// Without this guard, a no-DCA L1 short at prev_H would scalp 0.5% instead
// of riding the full 1-2% to prev_mid, giving up most of the strategy edge.
tpLongAvgPct  = na(avgEntryPx) ? na : avgEntryPx * (1 + smartTpPct)
tpShortAvgPct = na(avgEntryPx) ? na : avgEntryPx * (1 - smartTpPct)
tpLongSmart   = (filledCount > 1 and not na(tpLongAvgPct))  ? math.min(prevMidLong,  tpLongAvgPct)  : prevMidLong
tpShortSmart  = (filledCount > 1 and not na(tpShortAvgPct)) ? math.max(prevMidShort, tpShortAvgPct) : prevMidShort

// Hybrid TP: prev_mid until DCA fires, then switch to fixed % from FIRST
// entry. Reasoning — pre-DCA, the trade is on a small leg and prev_mid is
// usually within reach; post-DCA, avg entry has shifted away from prev_mid
// so a fixed-% target from first entry (e.g., 4%) often lets the winner
// run further than prev_mid would. Uses the existing tpFixedPct param.
tpLongHybrid  = (filledCount > 1 and not na(tpLongFixed))  ? tpLongFixed  : prevMidLong
tpShortHybrid = (filledCount > 1 and not na(tpShortFixed)) ? tpShortFixed : prevMidShort

tpLongPx  = tpMode == "smart" ? tpLongSmart
         : tpMode == "hybrid" ? tpLongHybrid
         : tpMode == "prev_mid" ? prevMidLong
         : tpMode == "prev_extreme" ? prevH
         : tpLongFixed
tpShortPx = tpMode == "smart" ? tpShortSmart
         : tpMode == "hybrid" ? tpShortHybrid
         : tpMode == "prev_mid" ? prevMidShort
         : tpMode == "prev_extreme" ? prevL
         : tpShortFixed
slLongPx  = worstEntryPx * (1 - slBelowWorst)
slShortPx = worstEntryPx * (1 + slBelowWorst)

if strategy.position_size > 0 and not na(worstEntryPx)
    // Exit all long legs at TP=prevMid or SL=2% below worst entry
    strategy.exit("xL1", from_entry="L1", limit=tpLongPx, stop=slLongPx)
    if filledCount >= 2
        strategy.exit("xL2", from_entry="L2", limit=tpLongPx, stop=slLongPx)
    if filledCount >= 3
        strategy.exit("xL3", from_entry="L3", limit=tpLongPx, stop=slLongPx)

if strategy.position_size < 0 and not na(worstEntryPx)
    strategy.exit("xS1", from_entry="S1", limit=tpShortPx, stop=slShortPx)
    if filledCount >= 2
        strategy.exit("xS2", from_entry="S2", limit=tpShortPx, stop=slShortPx)
    if filledCount >= 3
        strategy.exit("xS3", from_entry="S3", limit=tpShortPx, stop=slShortPx)

// ─── EOD flatten (optional) ───
if useEodFlatten and utcH >= closeHour and strategy.position_size != 0
    strategy.close_all(comment="EOD flatten")

// ─── Cycle reset after exit ───
if strategy.position_size == 0 and strategy.position_size[1] != 0
    cycleClosedOnDay := dayofmonth
    filledCount     := 0
    firstEntryPx    := na
    worstEntryPx    := na
    cumNotional     := na
    cumQty          := na

// ─── Visuals ───
plot(prevH, "Prev H",   color=color.new(color.red,   50), style=plot.style_linebr)
plot(prevL, "Prev L",   color=color.new(color.green, 50), style=plot.style_linebr)
plot(prevMid, "Prev Mid (TP)", color=color.new(color.aqua, 30), style=plot.style_linebr)
plot(strategy.position_size != 0 and not na(worstEntryPx)
     ? (strategy.position_size > 0 ? slLongPx : slShortPx) : na,
     "Active SL", color=color.new(color.red, 20), style=plot.style_linebr, linewidth=2)

// Active TP — shows where TP currently sits (moves with smart mode after DCA)
plot(strategy.position_size != 0 and not na(firstEntryPx)
     ? (strategy.position_size > 0 ? tpLongPx : tpShortPx) : na,
     "Active TP", color=color.new(color.aqua, 0), style=plot.style_linebr, linewidth=2)

// Avg entry — shows where the cycle's weighted avg entry sits (smart-TP anchor)
plot(strategy.position_size != 0 and not na(avgEntryPx) ? avgEntryPx : na,
     "Avg Entry", color=color.new(color.yellow, 30), style=plot.style_linebr, linewidth=1)

// 1h EMA plotted on chart for visual bias reference
plot(hourEma, "1h EMA", color=color.new(color.purple, 20), linewidth=2)

plotshape(l1LongOk,  "L1",  shape.triangleup,   location.belowbar, color.green, size=size.small)
plotshape(l1ShortOk, "S1",  shape.triangledown, location.abovebar, color.red,   size=size.small)

wrongTf = timeframe.period != "5"
if barstate.islast and wrongTf
    var table tfWarn = table.new(position.bottom_center, 1, 1, border_width=2, border_color=color.red)
    table.cell(tfWarn, 0, 0,
         "⚠ Chart TF is " + timeframe.period + " — designed for 5m",
         bgcolor=color.new(color.red, 15), text_color=color.white, text_size=size.normal)

// Dashboard
if barstate.islast
    var table dash = table.new(position.top_right, 2, 12, border_width=1)
    table.cell(dash, 0, 0, "S/R DCA Day", bgcolor=color.gray, text_color=color.white)
    table.cell(dash, 1, 0, "5m", bgcolor=color.teal, text_color=color.white)
    table.cell(dash, 0, 1, "EOD")
    table.cell(dash, 1, 1, useEodFlatten ? str.tostring(closeHour) + ":00 UTC" : "OFF", text_color=useEodFlatten ? color.green : color.gray)
    table.cell(dash, 0, 2, "Prev H / L / Mid")
    table.cell(dash, 1, 2, str.tostring(prevL, "#.##") + " / " + str.tostring(prevMid, "#.##") + " / " + str.tostring(prevH, "#.##"))
    table.cell(dash, 0, 3, "UTC hour")
    table.cell(dash, 1, 3, str.tostring(utcH) + ":00")
    table.cell(dash, 0, 4, "TP mode")
    table.cell(dash, 1, 4, tpMode + (tpMode == "fixed_pct" or tpMode == "hybrid" ? " " + str.tostring(tpFixedPct*100, "#.#") + "%" : tpMode == "smart" ? " " + str.tostring(smartTpPct*100, "#.#") + "%" : ""))
    table.cell(dash, 0, 5, "Filled")
    table.cell(dash, 1, 5, str.tostring(filledCount) + "/" + str.tostring(dcaLevels))
    table.cell(dash, 0, 6, "Position")
    table.cell(dash, 1, 6, strategy.position_size > 0 ? "LONG" : strategy.position_size < 0 ? "SHORT" : "FLAT",
         text_color=strategy.position_size > 0 ? color.green : strategy.position_size < 0 ? color.red : color.gray)
    table.cell(dash, 0, 7, "Avg entry")
    table.cell(dash, 1, 7, na(avgEntryPx) ? "—" : str.tostring(avgEntryPx, "#.##"))
    table.cell(dash, 0, 8, "Worst entry")
    table.cell(dash, 1, 8, na(worstEntryPx) ? "—" : str.tostring(worstEntryPx, "#.##"))
    table.cell(dash, 0, 9, "Active TP")
    table.cell(dash, 1, 9, strategy.position_size == 0 ? "—" : str.tostring(strategy.position_size > 0 ? tpLongPx : tpShortPx, "#.##"),
         text_color=color.aqua)
    table.cell(dash, 0, 10, "Cycle done today")
    table.cell(dash, 1, 10, cycleDone ? "YES" : "no")
    table.cell(dash, 0, 11, "Equity")
    table.cell(dash, 1, 11, "$" + str.tostring(strategy.equity, "#,###"))

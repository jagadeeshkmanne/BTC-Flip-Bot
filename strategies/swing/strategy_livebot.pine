//@version=6
// ─────────────────────────────────────────────────────────────────────
// BTC Swing Bot 1H — LIVE BOT REPLICA
// Mirrors strategies/swing/core.py running on GCP testnet.
//
// Architecture:
//   Daily: EMA50 trend bias (close > EMA50 = bull)
//   4H:    RSI(14) confirmation (>50 bull / <50 bear)
//   1H:    Execution — RSI(21) 40/60, MACD hist momentum, EMA50 slope(5)
//   Longs need: Daily bull + 4H RSI>50 + 1H RSI 40-100 + MACD bull + slope up
//   Shorts:     4H RSI<50 + 1H RSI 0-60 + MACD bear + slope down  (NO daily bear)
//   SL:    5-bar swing ± 0.1% buffer, cap 2.5%
//   TP ladder: TP1 40% @ 3R, TP2 15% @ 6R, move SL→BE after TP1
//   Pyramid: +50% @ 3R (half-risk, needs slope + RSI strength)
//   Vol-adj: ATR/price > 3% → half risk
//   Cooldown: 24h same-dir after SL, 2h generic
//   DD halt: 15% → halt 7 days
// ─────────────────────────────────────────────────────────────────────

leverageInput = input.float(2.0, "Leverage cap", minval=1, maxval=10, step=0.5)

strategy("BTC Swing Bot 1H - LIVE REPLICA", overlay=true, initial_capital=5000,
     default_qty_type=strategy.percent_of_equity, default_qty_value=95,
     pyramiding=1, calc_on_order_fills=false, calc_on_every_tick=false,
     process_orders_on_close=true, commission_type=strategy.commission.percent,
     commission_value=0.04, slippage=2,
     margin_long=0, margin_short=0, use_bar_magnifier=false)

// ─── Risk ───
grpRisk    = "⚙️ Risk"
riskPct    = input.float(1.0,  "Risk per trade (%)", minval=0.1, maxval=5, step=0.1, group=grpRisk) / 100
ddHaltPct  = input.float(15.0, "Drawdown halt (%)",  minval=5, maxval=50, group=grpRisk) / 100
ddHaltBars = input.int(168,    "Halt bars (168=7d on 1H)", minval=24, maxval=720, group=grpRisk)
volAdjPct  = input.float(3.0,  "Vol half-risk above ATR/price (%)", minval=1, maxval=10, step=0.5, group=grpRisk) / 100

// ─── SL / TP ───
grpSL      = "🛑 Stop Loss / TP"
slMaxPct   = input.float(2.5, "SL max (%)", minval=0.5, maxval=5, step=0.1, group=grpSL) / 100
slBufPct   = input.float(0.1, "SL buffer (%)", minval=0.0, maxval=1, step=0.05, group=grpSL) / 100
slSwingLen = input.int(5,   "Swing lookback", minval=2, maxval=20, group=grpSL)
tp1R       = input.float(3.0, "TP1 R-multiple", minval=1, maxval=10, step=0.5, group=grpSL)
tp1Frac    = input.float(0.40,"TP1 close fraction", minval=0.1, maxval=0.9, step=0.05, group=grpSL)
tp2R       = input.float(6.0, "TP2 R-multiple", minval=2, maxval=15, step=0.5, group=grpSL)
tp2Frac    = input.float(0.15,"TP2 close fraction", minval=0.05, maxval=0.5, step=0.05, group=grpSL)
beBufPct   = input.float(0.1, "BE buffer (%)", minval=0.0, maxval=1, step=0.05, group=grpSL) / 100

// ─── Entry ───
grpEntry   = "📊 Entry"
rsiPeriod  = input.int(21, "1H RSI period", minval=7, maxval=30, group=grpEntry)
rsiLongMin = input.float(40, "RSI min (long)",  minval=30, maxval=60, group=grpEntry)
rsiShortMax= input.float(60, "RSI max (short)", minval=40, maxval=70, group=grpEntry)
slopeBars  = input.int(5,  "EMA50 slope lookback", minval=2, maxval=20, group=grpEntry)

// ─── Pyramid ───
grpPyr     = "📈 Pyramid"
usePyramid = input.bool(true, "Enable pyramid", group=grpPyr)
pyrR       = input.float(3.0,  "Add at R", minval=1, maxval=10, step=0.5, group=grpPyr)
pyrFrac    = input.float(0.50, "Add fraction of original qty", minval=0.1, maxval=1, step=0.1, group=grpPyr)
pyrRsiL    = input.float(55,   "Long pyramid needs RSI >", minval=50, maxval=70, group=grpPyr)
pyrRsiS    = input.float(45,   "Short pyramid needs RSI <", minval=30, maxval=50, group=grpPyr)

// ─── Cooldown ───
grpCD       = "⏸️ Cooldown"
sameDirCd   = input.int(24, "Same-dir cooldown after SL (bars)", minval=0, maxval=168, group=grpCD)
genCooldown = input.int(2,  "Generic cooldown (bars)",           minval=0, maxval=20,  group=grpCD)

// ─── Visual ───
grpViz    = "🎨 Visual"
cleanView = input.bool(true,  "Clean view", group=grpViz)
showEma50 = input.bool(false, "Show Daily EMA50", group=grpViz)

// ─── HTF (Daily + 4H) ───
dailyClose = request.security(syminfo.tickerid, "1D", close[1], lookahead=barmerge.lookahead_off)
dailyEma50 = request.security(syminfo.tickerid, "1D", ta.ema(close, 50)[1], lookahead=barmerge.lookahead_off)
dailyBull  = dailyClose > dailyEma50

rsi4h = request.security(syminfo.tickerid, "240", ta.rsi(close, 14)[1], lookahead=barmerge.lookahead_off)
h4Bull = rsi4h > 50
h4Bear = rsi4h < 50

// ─── 1H Indicators ───
rsi = ta.rsi(close, rsiPeriod)
[macdLine, signalLine, macdHist] = ta.macd(close, 12, 26, 9)
histPrev = macdHist[1]
histSma  = ta.sma(macdHist, 10)

macdBull = macdHist > 0 and macdHist > histPrev and macdHist > histSma
macdBear = macdHist < 0 and macdHist < histPrev and macdHist < histSma

ema50   = ta.ema(close, 50)
slopeUp = ema50 > ema50[slopeBars]
slopeDn = ema50 < ema50[slopeBars]

// ATR for vol-adjust
atr20 = ta.atr(20)
atrNorm = atr20 / close

// Swing SL
swingLow   = ta.lowest(low, slSwingLen) * (1 - slBufPct)
swingHigh  = ta.highest(high, slSwingLen) * (1 + slBufPct)
cappedLow  = close * (1 - slMaxPct)
cappedHigh = close * (1 + slMaxPct)
stopLong   = math.max(swingLow, cappedLow)
stopShort  = math.min(swingHigh, cappedHigh)

// ─── Signals (asymmetric — matches core.py) ───
rsiOkL = rsi >= rsiLongMin
rsiOkS = rsi <= rsiShortMax

longSignal  = dailyBull and h4Bull and rsiOkL and macdBull and slopeUp
shortSignal = h4Bear and rsiOkS and macdBear and slopeDn  // no daily bear

// ─── State ───
var int   lastSlBarL    = na
var int   lastSlBarS    = na
var int   lastExitBar   = na
var int   haltUntilBar  = na
var float peakEquity    = strategy.initial_capital
var float entryRef      = na
var float stopRef       = na
var float slDistRef     = na
var bool  tp1Done       = false
var bool  tp2Done       = false
var bool  pyrDone       = false

wrongTf = timeframe.period != "60"

sameDirBlockL = not na(lastSlBarL) and (bar_index - lastSlBarL) < sameDirCd
sameDirBlockS = not na(lastSlBarS) and (bar_index - lastSlBarS) < sameDirCd
exitCdBlocked = not na(lastExitBar) and (bar_index - lastExitBar) < genCooldown
isHalted      = not na(haltUntilBar) and bar_index < haltUntilBar

canGoLong  = longSignal  and not sameDirBlockL and not exitCdBlocked and not isHalted
canGoShort = shortSignal and not sameDirBlockS and not exitCdBlocked and not isHalted

// DD halt
currentEquity = strategy.equity
peakEquity   := math.max(peakEquity, currentEquity)
drawdownPct   = (currentEquity - peakEquity) / peakEquity
if drawdownPct <= -ddHaltPct and strategy.position_size == 0
    haltUntilBar := bar_index + ddHaltBars
    peakEquity   := currentEquity

// ─── Sizing (with vol-adjust) ───
slDistLong  = close - stopLong
slDistShort = stopShort - close
volMult     = atrNorm > volAdjPct ? 0.5 : 1.0
riskAmount  = currentEquity * 0.95 * riskPct * volMult
qtyRiskL    = slDistLong  > 0 ? (riskAmount / slDistLong)  : 0
qtyRiskS    = slDistShort > 0 ? (riskAmount / slDistShort) : 0
qtyCap      = (currentEquity * 0.95 * leverageInput) / close
qtyLong     = math.min(qtyRiskL, qtyCap)
qtyShort    = math.min(qtyRiskS, qtyCap)

// ─── Entries ───
if canGoLong and strategy.position_size == 0 and qtyLong > 0
    strategy.entry("L", strategy.long, qty=qtyLong)
    entryRef  := close
    stopRef   := stopLong
    slDistRef := slDistLong
    tp1Done   := false
    tp2Done   := false
    pyrDone   := false

if canGoShort and strategy.position_size == 0 and qtyShort > 0
    strategy.entry("S", strategy.short, qty=qtyShort)
    entryRef  := close
    stopRef   := stopShort
    slDistRef := slDistShort
    tp1Done   := false
    tp2Done   := false
    pyrDone   := false

// ─── TP Ladder + BE move + Pyramid (longs) ───
if strategy.position_size > 0 and not na(entryRef)
    tp1Px = entryRef + tp1R * slDistRef
    tp2Px = entryRef + tp2R * slDistRef
    bePx  = entryRef * (1 + beBufPct)

    // TP1: close 40%
    if not tp1Done and high >= tp1Px
        strategy.close("L", qty_percent=tp1Frac * 100, comment="TP1")
        tp1Done := true
        stopRef := math.max(stopRef, bePx)  // move SL→BE

    // TP2: close another 15% of original
    if tp1Done and not tp2Done and high >= tp2Px
        strategy.close("L", qty_percent=(tp2Frac / (1 - tp1Frac)) * 100, comment="TP2")
        tp2Done := true

    // Pyramid: +50% original qty at 3R, needs slope + RSI>55
    pyrPx = entryRef + pyrR * slDistRef
    if usePyramid and not pyrDone and high >= pyrPx and slopeUp and rsi > pyrRsiL
        pyrQty = qtyLong * pyrFrac * 0.5  // half-risk
        if pyrQty > 0
            strategy.entry("L", strategy.long, qty=pyrQty, comment="PYR")
            pyrDone := true

    // Enforced stop/catastrophic exit
    strategy.exit("xL", from_entry="L", stop=stopRef)

// ─── TP Ladder + BE move + Pyramid (shorts) ───
if strategy.position_size < 0 and not na(entryRef)
    tp1Px = entryRef - tp1R * slDistRef
    tp2Px = entryRef - tp2R * slDistRef
    bePx  = entryRef * (1 - beBufPct)

    if not tp1Done and low <= tp1Px
        strategy.close("S", qty_percent=tp1Frac * 100, comment="TP1")
        tp1Done := true
        stopRef := math.min(stopRef, bePx)

    if tp1Done and not tp2Done and low <= tp2Px
        strategy.close("S", qty_percent=(tp2Frac / (1 - tp1Frac)) * 100, comment="TP2")
        tp2Done := true

    pyrPx = entryRef - pyrR * slDistRef
    if usePyramid and not pyrDone and low <= pyrPx and slopeDn and rsi < pyrRsiS
        pyrQty = qtyShort * pyrFrac * 0.5
        if pyrQty > 0
            strategy.entry("S", strategy.short, qty=pyrQty, comment="PYR")
            pyrDone := true

    strategy.exit("xS", from_entry="S", stop=stopRef)

// ─── Opposite signal close ───
if strategy.position_size > 0 and shortSignal
    strategy.close_all(comment="flip")
if strategy.position_size < 0 and longSignal
    strategy.close_all(comment="flip")

// ─── Track exits + SL side (for same-dir cooldown) ───
if strategy.position_size == 0 and strategy.position_size[1] != 0
    lastExitBar := bar_index
    // if exit near stop → treat as SL for cooldown
    if strategy.position_size[1] > 0 and low <= stopRef * 1.005
        lastSlBarL := bar_index
    if strategy.position_size[1] < 0 and high >= stopRef * 0.995
        lastSlBarS := bar_index
    entryRef := na

// ─── Visuals ───
plot(showEma50 ? dailyEma50 : na, "Daily EMA50", color=color.new(color.yellow, 40), linewidth=2)

plotshape(longSignal,  "Long",  shape.triangleup,   location.belowbar, color.green, size=size.tiny)
plotshape(shortSignal, "Short", shape.triangledown, location.abovebar, color.red,   size=size.tiny)

if barstate.islast and wrongTf
    var table tfWarn = table.new(position.bottom_center, 1, 1, border_width=2, border_color=color.red)
    table.cell(tfWarn, 0, 0,
         "⚠ Chart TF is " + timeframe.period + " — designed for 1H (60)",
         bgcolor=color.new(color.red, 15), text_color=color.white, text_size=size.normal)

bgcolor((not cleanView and isHalted) ? color.new(color.red, 85) : color(na), title="DD Halt")

// Dashboard
if barstate.islast and not cleanView
    var table dash = table.new(position.top_right, 2, 11, border_width=1)
    table.cell(dash, 0, 0, "LiveBot 1H", bgcolor=color.gray, text_color=color.white)
    table.cell(dash, 1, 0, str.tostring(leverageInput, "#.#") + "× LEV", bgcolor=color.teal, text_color=color.white)
    table.cell(dash, 0, 1, "Daily EMA50")
    table.cell(dash, 1, 1, dailyBull ? "BULL ✓" : "BEAR", text_color=dailyBull ? color.green : color.red)
    table.cell(dash, 0, 2, "4H RSI")
    table.cell(dash, 1, 2, str.tostring(rsi4h, "#.#") + (h4Bull ? " ↑" : h4Bear ? " ↓" : ""))
    table.cell(dash, 0, 3, "1H RSI(" + str.tostring(rsiPeriod) + ")")
    table.cell(dash, 1, 3, str.tostring(rsi, "#.#"))
    table.cell(dash, 0, 4, "MACD Hist")
    table.cell(dash, 1, 4, macdBull ? "BULL ✓" : macdBear ? "BEAR ✓" : "—",
         text_color=macdBull ? color.green : macdBear ? color.red : color.gray)
    table.cell(dash, 0, 5, "EMA50 slope")
    table.cell(dash, 1, 5, slopeUp ? "UP ✓" : slopeDn ? "DN ✓" : "flat",
         text_color=slopeUp ? color.green : slopeDn ? color.red : color.gray)
    table.cell(dash, 0, 6, "ATR/price")
    table.cell(dash, 1, 6, str.tostring(atrNorm * 100, "#.##") + "%" + (atrNorm > volAdjPct ? " (½)" : ""))
    table.cell(dash, 0, 7, "Long OK")
    table.cell(dash, 1, 7, longSignal ? "YES ✓" : "NO", text_color=longSignal ? color.green : color.gray)
    table.cell(dash, 0, 8, "Short OK")
    table.cell(dash, 1, 8, shortSignal ? "YES ✓" : "NO", text_color=shortSignal ? color.red : color.gray)
    table.cell(dash, 0, 9, "TP Ladder")
    table.cell(dash, 1, 9, str.tostring(tp1Frac*100,"#")+"%@"+str.tostring(tp1R,"#")+"R / "+str.tostring(tp2Frac*100,"#")+"%@"+str.tostring(tp2R,"#")+"R")
    table.cell(dash, 0, 10, "Equity")
    table.cell(dash, 1, 10, "$" + str.tostring(strategy.equity, "#,###"))

//@version=6
// ─────────────────────────────────────────────────────────────────────
// BTC Swing Bot — Structure Break Strategy (Daily)
//
// Final strategy after iterating — production on 1D timeframe.
//
// Logic:
//   - Daily EMA50 bias filter (prior-bar close, no lookahead)
//   - Daily RSI(14) > 50 for longs, < 50 for shorts
//   - Pivot-based structure: HH+HL pivots for longs, LH+LL for shorts
//   - Close must break latest pivot (breakout confirmation)
//   - SL: 5-bar swing ± 0.1% buffer, capped at 2.5%
//   - TP ladder: TP1 50%@2R (SL→BE), TP2 25%@4R, Runner 25% ATR-trail
//   - DD-adaptive risk: ddFactor = max(0.5, 1 + drawdownPct)
//   - Hard DD halt: 15% → halt 7 days
//   - Same-bar flip on opposite signal
//
// TradingView test (Sep 2019 → Apr 2026, 6.6y, 3% risk, 2× lev, pivotLen=3):
//   +673% | 42% DD | PF 2.43 | 47 trades | 57% WR | Calmar ~0.85
//
// pivotLen=3 is the optimum. pivotLen=2 adds trades but destroys edge
// (tested: +573% → +54%). 7 trades/year is the strategy's natural cadence.
// ─────────────────────────────────────────────────────────────────────

leverageInput = input.float(2.0, "Leverage cap", minval=1, maxval=10, step=0.5)

strategy("BTC Swing Bot - Structure Break (Daily)", overlay=true, initial_capital=5000,
     default_qty_type=strategy.percent_of_equity, default_qty_value=95,
     pyramiding=0, calc_on_order_fills=false, calc_on_every_tick=false,
     process_orders_on_close=true, commission_type=strategy.commission.percent,
     commission_value=0.04, slippage=3,
     margin_long=0, margin_short=0, use_bar_magnifier=false)

// ─── Risk ───
grpRisk    = "⚙️ Risk"
riskPct    = input.float(3.0,  "Risk per trade (%)", minval=0.1, maxval=5, step=0.1, group=grpRisk) / 100
useAdaptiveRisk = input.bool(true, "DD-adaptive risk scaling", group=grpRisk)
riskFloor  = input.float(0.5,  "Min risk mult (floor at DD)", minval=0.1, maxval=1.0, step=0.05, group=grpRisk,
     tooltip="At large drawdown, risk is reduced to (this × base risk). 0.5 = half risk at deep DD.")
ddHaltPct  = input.float(15.0, "Drawdown halt (%)", minval=5, maxval=50, group=grpRisk) / 100
ddHaltBars = input.int(7,      "Halt bars (7 = 7d on 1D)", minval=3, maxval=30, group=grpRisk)

// ─── SL / TP Ladder ───
grpSL        = "🛑 SL / TP Ladder"
slMaxPct     = input.float(2.5,  "SL max (%)", minval=0.5, maxval=5, step=0.1, group=grpSL) / 100
slBufPct     = input.float(0.1,  "SL buffer (%)", minval=0.0, maxval=1, step=0.05, group=grpSL) / 100
slSwingLen   = input.int(5,      "Swing lookback", minval=2, maxval=20, group=grpSL)
tp1R         = input.float(2.0,  "TP1 R-multiple", minval=1, maxval=10, step=0.5, group=grpSL)
tp1Frac      = input.float(0.50, "TP1 close fraction", minval=0.1, maxval=0.9, step=0.05, group=grpSL)
tp2R         = input.float(4.0,  "TP2 R-multiple", minval=2, maxval=15, step=0.5, group=grpSL)
tp2Frac      = input.float(0.25, "TP2 close fraction", minval=0.05, maxval=0.5, step=0.05, group=grpSL)
beBufPct     = input.float(0.1,  "BE buffer after TP1 (%)", minval=0.0, maxval=1, step=0.05, group=grpSL) / 100
trailAtrMult = input.float(2.5,  "Runner trail (× ATR)", minval=1, maxval=6, step=0.5, group=grpSL)

// ─── Entry ───
grpEntry  = "📊 Entry"
rsiPeriod = input.int(14, "RSI period", minval=7, maxval=30, group=grpEntry)
pivotLen  = input.int(3,  "Pivot lookback/forward", minval=1, maxval=10, group=grpEntry,
     tooltip="Peak on daily = 3. pivotLen=2 adds trades but destroys edge (tested: +572% → +54%).")

// ─── Cooldown ───
grpCD       = "⏸️ Cooldown"
genCooldown = input.int(3, "Cooldown (bars)", minval=0, maxval=20, group=grpCD)

// ─── Visual ───
grpViz    = "🎨 Visual"
cleanView = input.bool(true,  "Clean view", group=grpViz)
showEma50 = input.bool(false, "Show Daily EMA50", group=grpViz)

// ─── HTF ───
dailyClose = request.security(syminfo.tickerid, "1D", close[1], lookahead=barmerge.lookahead_off)
dailyEma50 = request.security(syminfo.tickerid, "1D", ta.ema(close, 50)[1], lookahead=barmerge.lookahead_off)
dailyBull  = dailyClose > dailyEma50
dailyBear  = dailyClose < dailyEma50

// ─── Indicators ───
rsi   = ta.rsi(close, rsiPeriod)
atr14 = ta.atr(14)

// ─── PIVOT STRUCTURE (V5 — unchanged) ───
pivHi = ta.pivothigh(high, pivotLen, pivotLen)
pivLo = ta.pivotlow(low,  pivotLen, pivotLen)

var float phLast = na
var float phPrev = na
var float plLast = na
var float plPrev = na

if not na(pivHi)
    phPrev := phLast
    phLast := pivHi
if not na(pivLo)
    plPrev := plLast
    plLast := pivLo

hhOk = not na(phLast) and not na(phPrev) and phLast > phPrev
hlOk = not na(plLast) and not na(plPrev) and plLast > plPrev
lhOk = not na(phLast) and not na(phPrev) and phLast < phPrev
llOk = not na(plLast) and not na(plPrev) and plLast < plPrev

bullStruct = hhOk and hlOk
bearStruct = lhOk and llOk
breakUp    = not na(phLast) and close > phLast
breakDn    = not na(plLast) and close < plLast

// Swing SL
swingLow   = ta.lowest(low, slSwingLen) * (1 - slBufPct)
swingHigh  = ta.highest(high, slSwingLen) * (1 + slBufPct)
cappedLow  = close * (1 - slMaxPct)
cappedHigh = close * (1 + slMaxPct)
stopLong   = math.max(swingLow, cappedLow)
stopShort  = math.min(swingHigh, cappedHigh)

// ─── Signals ───
longSignal  = dailyBull and rsi > 50 and bullStruct and breakUp
shortSignal = dailyBear and rsi < 50 and bearStruct and breakDn

// ─── State ───
var int   lastExitBar  = na
var int   haltUntilBar = na
var float peakEquity   = strategy.initial_capital
var float entryRef     = na
var float stopRef      = na
var float slDistRef    = na
var bool  tp1Done      = false
var bool  tp2Done      = false

wrongTf = timeframe.period != "D" and timeframe.period != "1D"

exitCdBlocked = not na(lastExitBar) and (bar_index - lastExitBar) < genCooldown
isHalted      = not na(haltUntilBar) and bar_index < haltUntilBar

canGoLong  = longSignal  and not exitCdBlocked and not isHalted
canGoShort = shortSignal and not exitCdBlocked and not isHalted

// Equity + DD tracking
currentEquity = strategy.equity
peakEquity   := math.max(peakEquity, currentEquity)
drawdownPct   = (currentEquity - peakEquity) / peakEquity  // <= 0

// Hard DD halt (separate from adaptive scaling)
if drawdownPct <= -ddHaltPct and strategy.position_size == 0
    haltUntilBar := bar_index + ddHaltBars
    peakEquity   := currentEquity

// ─── DD-ADAPTIVE RISK ───
// At 0% DD: ddFactor = 1.0 (full risk)
// At -10% DD: ddFactor = 0.9, at -30% DD: 0.7, at -50% DD: 0.5 (floor)
ddFactor = useAdaptiveRisk ? math.max(riskFloor, 1 + drawdownPct) : 1.0
effRisk = riskPct * ddFactor

// ─── Sizing ───
slDistLong  = close - stopLong
slDistShort = stopShort - close
riskAmount  = currentEquity * 0.95 * effRisk
qtyRiskL    = slDistLong  > 0 ? (riskAmount / slDistLong)  : 0
qtyRiskS    = slDistShort > 0 ? (riskAmount / slDistShort) : 0
qtyCap      = (currentEquity * 0.95 * leverageInput) / close
qtyLong     = math.min(qtyRiskL, qtyCap)
qtyShort    = math.min(qtyRiskS, qtyCap)

// ─── Entries (no position_size==0 check — Pine's strategy.entry
//            auto-closes opposite direction and opens new on SAME bar) ───
if canGoLong and strategy.position_size <= 0 and qtyLong > 0
    strategy.entry("L", strategy.long, qty=qtyLong)
    entryRef  := close
    stopRef   := stopLong
    slDistRef := slDistLong
    tp1Done   := false
    tp2Done   := false

if canGoShort and strategy.position_size >= 0 and qtyShort > 0
    strategy.entry("S", strategy.short, qty=qtyShort)
    entryRef  := close
    stopRef   := stopShort
    slDistRef := slDistShort
    tp1Done   := false
    tp2Done   := false

// ─── TP Ladder + BE + Trailing (longs) ───
if strategy.position_size > 0 and not na(entryRef)
    tp1Px = entryRef + tp1R * slDistRef
    tp2Px = entryRef + tp2R * slDistRef

    if not tp1Done and high >= tp1Px
        strategy.close("L", qty_percent=tp1Frac * 100, comment="TP1")
        tp1Done := true
        stopRef := math.max(stopRef, entryRef * (1 + beBufPct))

    if tp1Done and not tp2Done and high >= tp2Px
        strategy.close("L", qty_percent=(tp2Frac / (1 - tp1Frac)) * 100, comment="TP2")
        tp2Done := true

    if tp2Done
        trailStop = close - trailAtrMult * atr14
        stopRef := math.max(stopRef, trailStop)

    strategy.exit("xL", from_entry="L", stop=stopRef)

// ─── TP Ladder + BE + Trailing (shorts) ───
if strategy.position_size < 0 and not na(entryRef)
    tp1Px = entryRef - tp1R * slDistRef
    tp2Px = entryRef - tp2R * slDistRef

    if not tp1Done and low <= tp1Px
        strategy.close("S", qty_percent=tp1Frac * 100, comment="TP1")
        tp1Done := true
        stopRef := math.min(stopRef, entryRef * (1 - beBufPct))

    if tp1Done and not tp2Done and low <= tp2Px
        strategy.close("S", qty_percent=(tp2Frac / (1 - tp1Frac)) * 100, comment="TP2")
        tp2Done := true

    if tp2Done
        trailStop = close + trailAtrMult * atr14
        stopRef := math.min(stopRef, trailStop)

    strategy.exit("xS", from_entry="S", stop=stopRef)

// ─── Opposite signal flip ───
// strategy.entry auto-closes opposite direction on same bar, so no explicit
// close_all needed. Entry conditions above (position_size <= 0 for long,
// >= 0 for short) allow firing while still in an opposite position.

// ─── Track exits ───
if strategy.position_size == 0 and strategy.position_size[1] != 0
    lastExitBar := bar_index
    entryRef := na

// ─── Visuals ───
plot(showEma50 ? dailyEma50 : na, "Daily EMA50", color=color.new(color.yellow, 40), linewidth=2)

plotshape(longSignal,  "Long",  shape.triangleup,   location.belowbar, color.green, size=size.small)
plotshape(shortSignal, "Short", shape.triangledown, location.abovebar, color.red,   size=size.small)

if barstate.islast and wrongTf
    var table tfWarn = table.new(position.bottom_center, 1, 1, border_width=2, border_color=color.red)
    table.cell(tfWarn, 0, 0,
         "⚠ Chart TF is " + timeframe.period + " — designed for 1D (Daily)",
         bgcolor=color.new(color.red, 15), text_color=color.white, text_size=size.normal)

bgcolor((not cleanView and isHalted) ? color.new(color.red, 85) : color(na), title="DD Halt")

// Dashboard
if barstate.islast and not cleanView
    var table dash = table.new(position.top_right, 2, 12, border_width=1)
    table.cell(dash, 0, 0, "Structure Break", bgcolor=color.gray, text_color=color.white)
    table.cell(dash, 1, 0, str.tostring(leverageInput, "#.#") + "× LEV", bgcolor=color.teal, text_color=color.white)
    table.cell(dash, 0, 1, "Daily EMA50")
    table.cell(dash, 1, 1, dailyBull ? "BULL ✓" : "BEAR", text_color=dailyBull ? color.green : color.red)
    table.cell(dash, 0, 2, "RSI")
    table.cell(dash, 1, 2, str.tostring(rsi, "#.#"))
    table.cell(dash, 0, 3, "HH + HL")
    table.cell(dash, 1, 3, bullStruct ? "YES ✓" : "NO", text_color=bullStruct ? color.green : color.gray)
    table.cell(dash, 0, 4, "LH + LL")
    table.cell(dash, 1, 4, bearStruct ? "YES ✓" : "NO", text_color=bearStruct ? color.red : color.gray)
    table.cell(dash, 0, 5, "Current DD")
    table.cell(dash, 1, 5, str.tostring(drawdownPct * 100, "#.##") + "%",
         text_color=drawdownPct < -0.15 ? color.red : drawdownPct < -0.05 ? color.orange : color.green)
    table.cell(dash, 0, 6, "Risk mult (adaptive)")
    table.cell(dash, 1, 6, "×" + str.tostring(ddFactor, "#.##"),
         text_color=ddFactor < 1.0 ? color.orange : color.green)
    table.cell(dash, 0, 7, "Effective risk")
    table.cell(dash, 1, 7, str.tostring(effRisk * 100, "#.##") + "%")
    table.cell(dash, 0, 8, "TP Ladder")
    table.cell(dash, 1, 8, str.tostring(tp1Frac*100,"#")+"%@"+str.tostring(tp1R,"#")+"R / "+str.tostring(tp2Frac*100,"#")+"%@"+str.tostring(tp2R,"#")+"R")
    table.cell(dash, 0, 9, "Position")
    table.cell(dash, 1, 9, strategy.position_size > 0 ? "LONG" : strategy.position_size < 0 ? "SHORT" : "FLAT",
         text_color=strategy.position_size > 0 ? color.green : strategy.position_size < 0 ? color.red : color.gray)
    table.cell(dash, 0, 10, "TP status")
    table.cell(dash, 1, 10, tp2Done ? "TP1+TP2 (runner)" : tp1Done ? "TP1 (BE)" : "—")
    table.cell(dash, 0, 11, "Equity")
    table.cell(dash, 1, 11, "$" + str.tostring(strategy.equity, "#,###"))

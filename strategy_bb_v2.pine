//@version=6
// ─────────────────────────────────────────────────────────────────────
// BTC BB Confluence V2 — 4H + 1H Bollinger Band Mean Reversion
//
// Author:  Jagadeesh Manne
// Version: V2 (April 2026)
//
// Buy when price hits BOTH 4H BB lower AND 1H BB lower + RSI oversold + volume spike.
// Short when price hits BOTH 4H BB upper AND 1H BB upper + RSI overbought + vol.
// TP: 4H BB mid (center of range). Max hold 24h. Both long AND short.
//
// NOT trend-following. This is mean reversion — buy panics, sell bounces.
//
// Python backtest (5yr, Binance futures):
//   $5K → $2.21M (+238% CAGR, -12.7% DD, PF 2.40, 688 trades, 67% WR)
//
// Use ONLY on BTCUSDT | 1H chart | 2x leverage.
// ─────────────────────────────────────────────────────────────────────

leverageInput = input.float(2.0, "Leverage", minval=1, maxval=10, step=0.5)

strategy("BTC BB Confluence V2", overlay=true, initial_capital=5000,
     default_qty_type=strategy.percent_of_equity, default_qty_value=100,
     pyramiding=0, calc_on_order_fills=false, calc_on_every_tick=false,
     process_orders_on_close=true, commission_type=strategy.commission.percent,
     commission_value=0.04, slippage=3,
     margin_long=0, margin_short=0)

// ─── Settings ───
grpBB       = "Bollinger Bands"
bbPeriod    = input.int(20,    "BB Period", minval=5, maxval=50, group=grpBB)
bbStd       = input.float(2.0, "BB Std Dev", minval=1, maxval=4, step=0.1, group=grpBB)

grpEntry    = "Entry Filters"
rsiOversold = input.int(30,    "RSI Oversold (long)", minval=10, maxval=50, group=grpEntry,
     tooltip="Only enter LONG when RSI drops below this. 30 = deeper oversold, higher quality.")
rsiOverbought = input.int(70,  "RSI Overbought (short)", minval=50, maxval=90, group=grpEntry,
     tooltip="Only enter SHORT when RSI rises above this.")
volSpike    = input.float(1.3, "Volume spike ratio", minval=1.0, maxval=3.0, step=0.1, group=grpEntry,
     tooltip="Volume must be above this x SMA20 to qualify.")
nearPct     = input.float(1.0, "Near 4H BB (%)", minval=0.1, maxval=5, step=0.1, group=grpEntry,
     tooltip="Price must be within this % of 4H BB band for confluence.") / 100

grpExit     = "Exit Rules"
maxHoldBars = input.int(24,    "Max hold (bars)", minval=4, maxval=168, group=grpExit,
     tooltip="Force exit after N bars. 24 = 24h on 1H chart.")
ddHaltPct   = input.float(25,  "DD halt (%)", minval=10, maxval=50, group=grpExit) / 100
ddHaltBars  = input.int(168,   "DD halt duration (bars)", minval=24, maxval=720, group=grpExit)
cdBars      = input.int(4,     "Cooldown (bars)", minval=0, maxval=24, group=grpExit)

grpViz      = "Visuals"
showBB      = input.bool(true, "Show 1H BB bands", group=grpViz)
show4HBB    = input.bool(false, "Show 4H BB bands", group=grpViz)

// ─── 4H BB (causal: prior closed bar [1] to avoid lookahead) ───
bb4hMid_raw = request.security(syminfo.tickerid, "240", ta.sma(close, bbPeriod)[1], lookahead=barmerge.lookahead_off)
bb4hStd_raw = request.security(syminfo.tickerid, "240", ta.stdev(close, bbPeriod)[1], lookahead=barmerge.lookahead_off)

// Guard: only compute bands when 4H data is valid
bb4hValid = not na(bb4hMid_raw) and not na(bb4hStd_raw) and bb4hMid_raw > 0
bb4hMid   = bb4hValid ? bb4hMid_raw : na
bb4hUp    = bb4hValid ? bb4hMid_raw + bbStd * bb4hStd_raw : na
bb4hLo    = bb4hValid ? bb4hMid_raw - bbStd * bb4hStd_raw : na

// ─── 1H indicators ───
[bbMid, bbUp, bbLo] = ta.bb(close, bbPeriod, bbStd)
rsi1h   = ta.rsi(close, 14)
volSma  = ta.sma(volume, 20)
volOk   = not na(volSma) and volSma > 0 and volume > volSpike * volSma
atr1h   = ta.atr(14)

// ─── Entry conditions (with na guards) ───
nearLo4H = not na(bb4hLo) and bb4hLo > 0 and (close - bb4hLo) / bb4hLo < nearPct
nearUp4H = not na(bb4hUp) and bb4hUp > 0 and (bb4hUp - close) / bb4hUp < nearPct

longSignal  = not na(bbLo) and close <= bbLo and nearLo4H and not na(rsi1h) and rsi1h < rsiOversold and volOk
shortSignal = not na(bbUp) and close >= bbUp and nearUp4H and not na(rsi1h) and rsi1h > rsiOverbought and volOk

// ─── State ───
var int entryBar     = na
var int lastExitBar  = na
var int haltUntilBar = na
var float peakEquity = strategy.initial_capital

// ─── DD halt (closes open positions on halt) ───
currentEquity = strategy.equity
peakEquity   := math.max(peakEquity, currentEquity)
drawdownPct   = (currentEquity - peakEquity) / peakEquity
isHalted      = not na(haltUntilBar) and bar_index < haltUntilBar

if drawdownPct <= -ddHaltPct
    if strategy.position_size != 0
        strategy.close_all(comment="DD-HALT")
        lastExitBar := bar_index
    if na(haltUntilBar) or bar_index >= haltUntilBar
        haltUntilBar := bar_index + ddHaltBars
    peakEquity := currentEquity

// ─── Cooldown ───
exitCdBlocked = not na(lastExitBar) and (bar_index - lastExitBar) < cdBars

// ─── Position sizing ───
notionalQty = currentEquity > 0 ? (currentEquity * leverageInput) / close : 0

// ─── Max hold exit (sets lastExitBar for cooldown) ───
if strategy.position_size != 0 and not na(entryBar) and (bar_index - entryBar) >= maxHoldBars
    strategy.close_all(comment="TIME")
    lastExitBar := bar_index

// ─── Normal entries ───
canTrade = not isHalted and not exitCdBlocked and strategy.position_size == 0

if canTrade and longSignal and notionalQty > 0 and not na(bb4hLo) and not na(bb4hMid) and not na(atr1h)
    slPrice = bb4hLo - atr1h
    tpPrice = bb4hMid
    slDist  = math.abs(close - slPrice)
    // Ensure SL is below entry and TP is above entry
    if slPrice < close and tpPrice > close and slDist / close > 0.003
        strategy.entry("L", strategy.long, qty=notionalQty)
        strategy.exit("xL", from_entry="L", stop=slPrice, limit=tpPrice)
        entryBar := bar_index

if canTrade and shortSignal and notionalQty > 0 and not na(bb4hUp) and not na(bb4hMid) and not na(atr1h)
    slPrice = bb4hUp + atr1h
    tpPrice = bb4hMid
    slDist  = math.abs(close - slPrice)
    // Ensure SL is above entry and TP is below entry
    if slPrice > close and tpPrice < close and slDist / close > 0.003
        strategy.entry("S", strategy.short, qty=notionalQty)
        strategy.exit("xS", from_entry="S", stop=slPrice, limit=tpPrice)
        entryBar := bar_index

// ─── Track exits for cooldown ───
if strategy.position_size == 0 and strategy.position_size[1] != 0
    lastExitBar := bar_index

// ─── Visuals ───
plot(showBB ? bbUp : na, "1H BB Upper", color=color.new(color.blue, 60), linewidth=1)
plot(showBB ? bbMid : na, "1H BB Mid", color=color.new(color.gray, 60), linewidth=1)
plot(showBB ? bbLo : na, "1H BB Lower", color=color.new(color.blue, 60), linewidth=1)
plot(show4HBB ? bb4hUp : na, "4H BB Upper", color=color.new(color.orange, 40), linewidth=2)
plot(show4HBB ? bb4hMid : na, "4H BB Mid", color=color.new(color.yellow, 40), linewidth=2)
plot(show4HBB ? bb4hLo : na, "4H BB Lower", color=color.new(color.orange, 40), linewidth=2)

// ─── Wrong TF warning ───
wrongTf = timeframe.period != "60"
if barstate.islast and wrongTf
    var table tfWarn = table.new(position.bottom_center, 1, 1, border_width=2, border_color=color.red)
    table.cell(tfWarn, 0, 0,
         "Warning: Chart is " + timeframe.period + " — Strategy tested on 1H only.",
         bgcolor=color.new(color.red, 15), text_color=color.white, text_size=size.normal)

// ─── Dashboard ───
if barstate.islast
    var table dash = table.new(position.top_right, 2, 8, border_width=1)
    table.cell(dash, 0, 0, "BB Confluence V2", bgcolor=color.gray, text_color=color.white)
    table.cell(dash, 1, 0, str.tostring(leverageInput, "#.#") + "x LEV", bgcolor=color.teal, text_color=color.white)

    table.cell(dash, 0, 1, "1H RSI(14)")
    rsiClr = rsi1h < rsiOversold ? color.green : rsi1h > rsiOverbought ? color.red : color.white
    table.cell(dash, 1, 1, str.tostring(rsi1h, "#.#"), text_color=rsiClr)

    table.cell(dash, 0, 2, "1H BB")
    bbTxt = close <= bbLo ? "AT LOWER" : close >= bbUp ? "AT UPPER" : "MIDDLE"
    bbClr = close <= bbLo ? color.green : close >= bbUp ? color.red : color.gray
    table.cell(dash, 1, 2, bbTxt, text_color=bbClr)

    table.cell(dash, 0, 3, "4H BB near")
    nearTxt = nearLo4H ? "NEAR LOW" : nearUp4H ? "NEAR HIGH" : "—"
    nearClr = nearLo4H ? color.green : nearUp4H ? color.red : color.gray
    table.cell(dash, 1, 3, nearTxt, text_color=nearClr)

    table.cell(dash, 0, 4, "Vol spike")
    volRatio = volSma > 0 ? volume / volSma : 0.0
    volTxt = str.tostring(volRatio, "#.##") + "x" + (volOk ? " ok" : "")
    table.cell(dash, 1, 4, volTxt, text_color=volOk ? color.green : color.gray)

    table.cell(dash, 0, 5, "Signal")
    sigTxt = longSignal ? "LONG" : shortSignal ? "SHORT" : "—"
    sigClr = longSignal ? color.green : shortSignal ? color.red : color.gray
    table.cell(dash, 1, 5, sigTxt, text_color=sigClr)

    table.cell(dash, 0, 6, "Position")
    posTxt = strategy.position_size > 0 ? "LONG" : strategy.position_size < 0 ? "SHORT" : "FLAT"
    posClr = strategy.position_size > 0 ? color.green : strategy.position_size < 0 ? color.red : color.gray
    table.cell(dash, 1, 6, posTxt, text_color=posClr)

    table.cell(dash, 0, 7, "Equity")
    table.cell(dash, 1, 7, "$" + str.tostring(strategy.equity, "#,###"))
